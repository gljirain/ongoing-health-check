# Copy to .env and fill in.

# Local SQLite (private mode). For cloud, switch the provider in
# prisma/schema.prisma to "postgresql" and use your Postgres URL here.
DATABASE_URL="file:./dev.db"

# Optional — enables live "Ask AI" deep-dives. Add either / both.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"
OPENAI_MODEL="gpt-5.5"
