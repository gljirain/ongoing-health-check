<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Hardened-runtime entitlements required for THIS app to run after signing.
    The app relaunches the Electron binary as Node (ELECTRON_RUN_AS_NODE) to run
    the Next.js standalone server, and loads Prisma's native query-engine .node
    module. Without these, a signed+notarized build crashes on launch.
  -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Load the Prisma native engine + run the Electron binary as Node. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- We pass env vars (DATABASE_URL, ELECTRON_RUN_AS_NODE, PORT) to the child. -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
</dict>
</plist>
